# Server
PORT=9988

# Public URL used in Telegram links (your subdomain pointing to this machine)
# Example: https://yt.yourdomain.com
BASE_URL=https://yt.example.com

# Master password for the admin download page (/)
MASTER_PASSWORD=change-me-to-a-strong-password

# Used to sign video access cookies — generate a long random string
SESSION_SECRET=change-me-to-a-long-random-secret

# Telegram bot credentials
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789

# Optional paths (defaults shown)
# DATA_DIR=./data
# VIDEOS_DIR=./data/videos
# DB_PATH=./data/yt-do.db
# YT_DLP_PATH=./data/bin/yt-dlp
# YT_DLP_JS_RUNTIME=bun:/usr/local/bin/bun
# YT_DLP_COOKIES_FILE=./data/cookies/youtube.txt
